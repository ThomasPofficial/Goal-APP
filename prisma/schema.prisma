// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// AUTH (NextAuth v5 required tables)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// CORE DOMAIN
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  profile               Profile?
  projectMemberships    ProjectMember[]
  notes                 Note[]
  sentMessages          Message[]                 @relation("SentMessages")
  participations        ConversationParticipant[]
  endorsementsGiven     PeerEndorsement[]         @relation("EndorsementsGiven")
  endorsementsReceived  PeerEndorsement[]         @relation("EndorsementsReceived")
}

model Profile {
  id              String      @id @default(cuid())
  userId          String      @unique
  displayName     String
  headline        String?
  bio             String?
  strengthSummary String?
  avatarUrl       String?
  geniusType      GeniusType?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  traitLinks  ProfileTrait[]
}

enum GeniusType {
  DYNAMO
  BLAZE
  TEMPO
  STEEL
}

// ─────────────────────────────────────────────
// TRAITS
// ─────────────────────────────────────────────

model Trait {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String
  category    TraitCategory
  createdAt   DateTime      @default(now())

  profileLinks       ProfileTrait[]
  peerEndorsements   PeerEndorsedTrait[]
}

model ProfileTrait {
  id        String   @id @default(cuid())
  profileId String
  traitId   String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  trait   Trait   @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([profileId, traitId])
}

enum TraitCategory {
  VISION
  DRIVE
  LEADERSHIP
  COMMUNICATION
  COLLABORATION
  ORGANIZATION
  ANALYTICAL
  ADAPTABILITY
  INTEGRITY
  JUDGMENT
}

// ─────────────────────────────────────────────
// PROJECTS (replaces generic Team)
// A project is the unit of collaboration.
// You handpick members for a specific project.
// When the project completes, endorsements are triggered.
// ─────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  goal        String?
  status      ProjectStatus @default(ACTIVE)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members           ProjectMember[]
  endorsements      PeerEndorsement[]
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ProjectRole {
  OWNER
  MEMBER
}

// ─────────────────────────────────────────────
// PEER ENDORSEMENTS
// After a project completes, each member can endorse
// each other member's top 5 traits.
// Stored separately from self-selected traits so both
// are shown on the Skill Card clearly.
// ─────────────────────────────────────────────

model PeerEndorsement {
  id          String    @id @default(cuid())
  projectId   String
  endorserId  String
  endorseeId  String
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  endorser User               @relation("EndorsementsGiven", fields: [endorserId], references: [id], onDelete: Cascade)
  endorsee User               @relation("EndorsementsReceived", fields: [endorseeId], references: [id], onDelete: Cascade)
  traits   PeerEndorsedTrait[]

  @@unique([projectId, endorserId, endorseeId])
}

model PeerEndorsedTrait {
  id            String   @id @default(cuid())
  endorsementId String
  traitId       String
  createdAt     DateTime @default(now())

  endorsement PeerEndorsement @relation(fields: [endorsementId], references: [id], onDelete: Cascade)
  trait       Trait           @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([endorsementId, traitId])
}

// ─────────────────────────────────────────────
// NOTES
// ─────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  authorId  String
  title     String?
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime  @default(now())
  editedAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}
